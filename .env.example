# v91-core-system Environment Configuration
# Copy to .env and fill in values before starting the stack.
# NEVER commit the actual .env file to version control.

# ── v91 Interop Listener ──────────────────────────────────────────────────────

# Path to the SQLite database inside the container
V91_DB_PATH=/app/data/v91_independent_state.db

# Directory watched for incoming interop events (JSON files)
V91_INBOX_PATH=/app/data/inbox

# Path to the HMAC secret key file (mounted read-only)
V91_SECRET_KEY_PATH=/app/secrets/v91_secret.key

# Inline HMAC secret (used when key file is not mounted; prefer key file in prod)
# V91_SECRET_KEY=change_me_in_production

# Seconds between inbox polls (default: 5)
V91_POLL_INTERVAL=5

# Confidence threshold below which events are routed to the HITL queue (0.0–1.0)
V91_HITL_THRESHOLD=0.75

# ── Controller ────────────────────────────────────────────────────────────────

PYTHONUNBUFFERED=1
